# Copy to .env and adjust as needed. All values are optional.

# Server
PORT=3001
# Host to bind. Defaults to 127.0.0.1 (local-only). Set to 0.0.0.0 to expose.
HOST=127.0.0.1
# Allowed CORS origin (the frontend). Defaults to the Vite dev server.
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development

# Optional API key. When set, every /api request must send `X-API-Key: <value>`.
# Leave unset to disable auth (local development).
# API_KEY=change-me

# Rate limiting (per IP, across /api)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Crawl limits
CRAWL_MAX_PAGES=100
CRAWL_MAX_CONCURRENT=2

# Puppeteer: only disable the sandbox in trusted/containerized environments
# where the Chromium sandbox cannot run (e.g. Docker as root).
# PUPPETEER_NO_SANDBOX=true

# Proxy support (optional)
# PROXY_ENABLED=true
# PROXIES=[{"host":"proxy.example.com","port":8080,"username":"u","password":"p","protocol":"http"}]
